																"type": "float"
															},
															"length": {
																"type": "float"
															},
															"position": {
																"properties": {
																	"top": {
																		"type": "float"
																	},
																	"left": {
																		"type": "float"
																	}
																}
															}
														}
													},
													"layerColors": {
														"type": "nested",
														"properties": {
															"type": {
																"type": "keyword"
															},
															"gradientType": {
																"type": "keyword"
															},
															"angle": {
																"type": "float"
															},
															"colors": {
																"type": "nested",
																"properties": {
																	"color": {
																		"type": "keyword"
																	},
																	"opacity": {
																		"type": "float"
																	},
																	"position": {
																		"type": "float"
																	}
																}
															}
														}
													},
													"innerMaskPoints": {
														"type": "nested",
														"properties": {
															"x": {
																"type": "float"
															},
															"y": {
																"type": "float"
															},
															"radius": {
																"type": "float"
															}
														}
													},
													"maskPoints": {
														"type": "nested",
														"properties": {
															"x": {
																"type": "float"
															},
															"y": {
																"type": "float"
															},
															"radius": {
																"type": "float"
															}
														}
													}
												}
											}
										}
									},
									"artworkLayouts": {
										"type": "nested",
										"properties": {
											"baseImageUrl": {
												"type": "keyword"
											},
											"side": { "type": "keyword" },
											"placementId": {
												"type": "keyword"
											},
											"length": { "type": "float" },
											"width": { "type": "float" },
											"containerRatio": {
												"properties": {
													"x": { "type": "float" },
													"y": { "type": "float" }
												}
											},
											"outerBlock": {
												"properties": {
													"length": {
														"type": "float"
													},
													"width": {
														"type": "float"
													},
													"position": {
														"properties": {
															"top": {
																"type": "float"
															},
															"left": {
																"type": "float"
															}
														}
													}
												}
											},
											"types": {
												"type": "nested",
												"properties": {
													"name": {
														"type": "keyword"
													}
												}
											},
											"innerBlocks": {
												"type": "nested",
												"properties": {
													"hidden": {
														"type": "boolean"
													},
													"isBackground": {
														"type": "boolean"
													},
													"label": {
														"type": "keyword"
													},
													"placeholder": {
														"type": "keyword"
													},
													"length": {
														"type": "float"
													},
													"width": {
														"type": "float"
													},
													"rotation": {
														"type": "float"
													},
													"rotationX": {
														"type": "float"
													},
													"rotationY": {
														"type": "float"
													},
													"radius": {
														"type": "float"
													},
													"imageFit": {
														"type": "keyword"
													},
													"opacity": {
														"type": "float"
													},
													"scale": {
														"type": "float"
													},
													"maskImageUrl": {
														"type": "keyword"
													},
													"blendMode": {
														"type": "keyword"
													},
													"unitOfMeasurement": {
														"type": "keyword"
													},
													"position": {
														"properties": {
															"top": {
																"type": "float"
															},
															"left": {
																"type": "float"
															}
														}
													},
													"layerColors": {
														"type": "nested",
														"properties": {
															"type": {
																"type": "keyword"
															},
															"gradientType": {
																"type": "keyword"
															},
															"angle": {
																"type": "float"
															},
															"colors": {
																"type": "nested",
																"properties": {
																	"color": {
																		"type": "keyword"
																	},
																	"opacity": {
																		"type": "float"
																	},
																	"position": {
																		"type": "float"
																	}
																}
															}
														}
													},
													"innerMaskPoints": {
														"type": "nested",
														"properties": {
															"x": {
																"type": "float"
															},
															"y": {
																"type": "float"
															},
															"radius": {
																"type": "float"
															}
														}
													},
													"maskPoints": {
														"type": "nested",
														"properties": {
															"x": {
																"type": "float"
															},
															"y": {
																"type": "float"
															},
															"radius": {
																"type": "float"
															}
														}
													}
												}
											}
										}
									}
								}
							}
						}
					}
				},
				{
					"id": "create_search_pipeline",
					"type": "create_search_pipeline",
					"previous_node_inputs": {
						"create_ingest_pipeline": "pipeline_id"
					},
					"user_inputs": {
						"pipeline_id": "${{ search_pipeline_id }}",
						"configurations": {
							"description": "Hybrid score fusion for product search",
							"phase_results_processors": [
								{
									"normalization-processor": {
										"normalization": {
											"technique": "min_max"
										},
										"combination": {
											"technique": "arithmetic_mean",
											"parameters": {
												"weights": [0.6, 0.4]
											}
										}
									}
								}
							]
						}
					}
				}
			],
			"edges": [
				{ "source": "create_ingest_pipeline", "dest": "create_index" },
				{
					"source": "create_ingest_pipeline",
					"dest": "create_search_pipeline"
				}
			]
		}
	}
}
